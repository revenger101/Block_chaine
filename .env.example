# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is already in .gitignore.

# ── Pinata IPFS credentials ───────────────────────────────────────────
# Get these at https://app.pinata.cloud/developers/api-keys
REACT_APP_PINATA_API_KEY=your_pinata_api_key_here
REACT_APP_PINATA_SECRET=your_pinata_secret_here

# ── Smart contract address ────────────────────────────────────────────
# Fill this in AFTER running: truffle migrate  (inside the blockchain/ folder)
# You will find the address printed in the terminal under "contract address:"
REACT_APP_CONTRACT_ADDRESS=0xYOUR_GANACHE_CONTRACT_ADDRESS_HERE
